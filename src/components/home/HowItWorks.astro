---
const steps = [
  {
    number: '01',
    title: 'Select your file',
    description: 'Drop your PDF or image into the tool area, or click to browse. Files are read directly into browser memory — nothing is sent anywhere.',
    icon: '📂',
  },
  {
    number: '02',
    title: 'Process in your browser',
    description: 'WebAssembly-powered engines (pdf-lib, MUPDF, PDF.js) process your file inside a Web Worker thread. Your CPU does the work, not a server.',
    icon: '⚙️',
  },
  {
    number: '03',
    title: 'Download instantly',
    description: 'Your processed file is created as a download link from memory. The original and output are both cleared from memory when you close the tab.',
    icon: '⬇️',
  },
];
---

<section class="px-4 py-16 sm:px-6" aria-labelledby="how-heading">
  <div class="mx-auto max-w-7xl">
    <div class="text-center">
      <h2 id="how-heading" class="text-2xl font-semibold text-[var(--color-text-primary)] sm:text-3xl">
        How It Works
      </h2>
      <p class="mt-3 text-[var(--color-text-secondary)]">
        Three steps, zero uploads, complete privacy.
      </p>
    </div>

    <div class="mt-12 grid gap-8 sm:grid-cols-3">
      {steps.map((step, i) => (
        <div class="relative flex flex-col items-center text-center">
          <!-- Step number -->
          <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-[var(--color-primary)] text-xl text-white shadow-sm" aria-hidden="true">
            {step.icon}
          </div>

          <!-- Connector line (between steps) -->
          {i < steps.length - 1 && (
            <div
              class="absolute left-[calc(50%+2rem)] top-7 hidden h-0.5 w-[calc(100%-4rem)] bg-[var(--color-border)] sm:block"
              aria-hidden="true"
            />
          )}

          <span class="mb-1 text-xs font-bold text-[var(--color-primary)]">STEP {step.number}</span>
          <h3 class="text-lg font-semibold text-[var(--color-text-primary)]">{step.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-[var(--color-text-secondary)]">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
