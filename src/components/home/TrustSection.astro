---
const pillars = [
  {
    icon: '🔒',
    title: 'No Uploads',
    description: 'Every byte of your files stays in your browser. WebAssembly processes PDFs and images entirely in your device\'s memory. Verify this yourself in DevTools — no network requests with file data.',
  },
  {
    icon: '👤',
    title: 'No Accounts',
    description: 'No sign-up, no email required, no login. Open the tool, use it, close the tab. Zero cookies, zero session tokens, zero tracking.',
  },
  {
    icon: '∞',
    title: 'No Limits',
    description: 'No daily caps, no paywalls, no watermarks on free tier. Process files up to 200MB as many times as you want. Core tools are free forever.',
  },
];
---

<section class="bg-[var(--color-surface)] px-4 py-16 sm:px-6" aria-labelledby="trust-heading">
  <div class="mx-auto max-w-7xl">
    <div class="text-center">
      <h2 id="trust-heading" class="text-2xl font-semibold text-[var(--color-text-primary)] sm:text-3xl">
        Why Docukit?
      </h2>
      <p class="mt-3 text-[var(--color-text-secondary)]">
        The only PDF and image toolkit that can prove your files stay private.
      </p>
    </div>

    <div class="mt-12 grid gap-8 sm:grid-cols-3">
      {pillars.map(({ icon, title, description }) => (
        <div class="text-center">
          <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-[var(--color-primary)]/10 text-2xl" aria-hidden="true">
            {icon}
          </div>
          <h3 class="text-lg font-semibold text-[var(--color-text-primary)]">{title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-[var(--color-text-secondary)]">{description}</p>
        </div>
      ))}
    </div>

    <!-- Technical trust proof -->
    <div class="mt-14 rounded-2xl border border-[var(--color-border)] bg-[var(--color-background)] p-6 text-center">
      <p class="text-sm text-[var(--color-text-secondary)]">
        <strong class="text-[var(--color-text-primary)]">Technical proof:</strong>
        Our Content Security Policy sets <code class="rounded bg-[var(--color-border)] px-1.5 py-0.5 text-xs font-mono">connect-src 'self'</code> — blocking ALL network requests to external servers. Open DevTools → Network tab and process any file. You'll see zero outbound requests with your file data.
      </p>
    </div>
  </div>
</section>
