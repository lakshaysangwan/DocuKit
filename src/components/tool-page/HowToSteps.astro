---
import type { HowToStep } from '@/lib/tools-registry';

interface Props {
  steps: HowToStep[];
  toolName: string;
}
const { steps, toolName } = Astro.props;
---

<section class="bg-[var(--color-surface)] px-4 py-12 sm:px-6" aria-labelledby="howto-heading">
  <div class="mx-auto max-w-4xl">
    <h2 id="howto-heading" class="text-xl font-semibold text-[var(--color-text-primary)]">
      How to {toolName}
    </h2>

    <ol class="mt-8 grid gap-6 sm:grid-cols-3" role="list">
      {steps.map((step, i) => (
        <li class="flex gap-4">
          <div
            class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[var(--color-primary)] text-sm font-bold text-white"
            aria-hidden="true"
          >
            {i + 1}
          </div>
          <div>
            <h3 class="font-medium text-[var(--color-text-primary)]">{step.title}</h3>
            <p class="mt-1 text-sm text-[var(--color-text-secondary)]">{step.description}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>
