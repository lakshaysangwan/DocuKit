---
import ThemeToggle from '@/components/islands/shared/ThemeToggle';
import { PDF_TOOLS, IMAGE_TOOLS } from '@/lib/tools-registry';
---

<header class="sticky top-0 z-50 border-b border-[var(--color-border)] bg-[var(--color-surface)]/90 backdrop-blur-md">
  <nav
    class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 sm:px-6"
    aria-label="Main navigation"
  >
    <!-- Logo -->
    <a
      href="/"
      class="flex items-center gap-2 text-lg font-semibold text-[var(--color-text-primary)] transition-opacity hover:opacity-80"
      aria-label="Docukit home"
    >
      <img src="/favicon.svg" alt="" class="h-7 w-7" width="28" height="28" />
      <span>Docukit</span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden items-center gap-1 md:flex">
      <!-- PDF Tools dropdown -->
      <div class="group relative">
        <button
          class="flex items-center gap-1 rounded-lg px-3 py-2 text-sm text-[var(--color-text-secondary)] transition-colors hover:bg-[var(--color-border)] hover:text-[var(--color-text-primary)]"
          aria-haspopup="true"
          aria-expanded="false"
        >
          PDF Tools
          <svg class="h-3 w-3 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div
          class="invisible absolute left-0 top-full z-50 mt-1 min-w-52 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-2 opacity-0 shadow-[var(--shadow-card-hover)] transition-all duration-150 group-hover:visible group-hover:opacity-100"
          role="menu"
        >
          {PDF_TOOLS.map(tool => (
            <a
              href={`/${tool.slug}`}
              class="block rounded-lg px-3 py-2 text-sm text-[var(--color-text-secondary)] transition-colors hover:bg-[var(--color-background)] hover:text-[var(--color-text-primary)]"
              role="menuitem"
            >
              {tool.name}
            </a>
          ))}
        </div>
      </div>

      <!-- Image Tools dropdown -->
      <div class="group relative">
        <button
          class="flex items-center gap-1 rounded-lg px-3 py-2 text-sm text-[var(--color-text-secondary)] transition-colors hover:bg-[var(--color-border)] hover:text-[var(--color-text-primary)]"
          aria-haspopup="true"
          aria-expanded="false"
        >
          Image Tools
          <svg class="h-3 w-3 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div
          class="invisible absolute left-0 top-full z-50 mt-1 min-w-48 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-2 opacity-0 shadow-[var(--shadow-card-hover)] transition-all duration-150 group-hover:visible group-hover:opacity-100"
          role="menu"
        >
          {IMAGE_TOOLS.map(tool => (
            <a
              href={`/${tool.slug}`}
              class="block rounded-lg px-3 py-2 text-sm text-[var(--color-text-secondary)] transition-colors hover:bg-[var(--color-background)] hover:text-[var(--color-text-primary)]"
              role="menuitem"
            >
              {tool.name}
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Actions -->
    <div class="flex items-center gap-2">
      <ThemeToggle client:load />
      <a
        href="https://github.com/lakshaysangwan/DocuKit"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Docukit on GitHub"
        class="hidden items-center gap-1.5 rounded-lg px-3 py-2 text-sm text-[var(--color-text-muted)] transition-colors hover:bg-[var(--color-border)] hover:text-[var(--color-text-primary)] md:flex"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.385-1.335-1.755-1.335-1.755-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
        </svg>
        GitHub
      </a>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="flex h-9 w-9 items-center justify-center rounded-lg text-[var(--color-text-secondary)] transition-colors hover:bg-[var(--color-border)] md:hidden"
        aria-label="Toggle mobile menu"
        aria-expanded="false"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-[var(--color-border)] px-4 pb-4 md:hidden">
    <div class="mt-3 space-y-1">
      <p class="px-3 py-1 text-xs font-medium uppercase tracking-wider text-[var(--color-text-muted)]">PDF Tools</p>
      {PDF_TOOLS.map(tool => (
        <a
          href={`/${tool.slug}`}
          class="block rounded-lg px-3 py-2 text-sm text-[var(--color-text-secondary)] hover:bg-[var(--color-border)] hover:text-[var(--color-text-primary)]"
        >
          {tool.name}
        </a>
      ))}
      <p class="mt-3 px-3 py-1 text-xs font-medium uppercase tracking-wider text-[var(--color-text-muted)]">Image Tools</p>
      {IMAGE_TOOLS.map(tool => (
        <a
          href={`/${tool.slug}`}
          class="block rounded-lg px-3 py-2 text-sm text-[var(--color-text-secondary)] hover:bg-[var(--color-border)] hover:text-[var(--color-text-primary)]"
        >
          {tool.name}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  // Mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(open));
  });
</script>
