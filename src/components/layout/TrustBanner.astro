---
// Static trust banner — shown on every page above the header
---
<div
  class="border-b border-[var(--color-border)] bg-[var(--color-primary)]/5 px-4 py-2 text-center text-sm"
  role="banner"
  aria-label="Privacy notice"
>
  <span class="text-[var(--color-text-secondary)]">
    🔒 Your files never leave your browser. All processing is 100% local.
    <a
      href="/privacy"
      class="ml-1 font-medium text-[var(--color-primary)] underline underline-offset-2 hover:no-underline"
    >
      How it works →
    </a>
  </span>
</div>
